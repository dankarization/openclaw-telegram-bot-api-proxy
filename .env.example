# Docker Telegram Bot API.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_LOCAL=1
BOT_API_PORT=8081
BOT_API_DATA_DIR=/home/danka/.openclaw/var/telegram-bot-api

# Proxy listener.
LISTEN_HOST=127.0.0.1
PORT=8082

# Upstreams.
LOCAL_API_ROOT=http://127.0.0.1:8081
CLOUD_API_ROOT=https://api.telegram.org
ENABLE_CLOUD_FALLBACK=1

# OpenClaw state.
TELEGRAM_OFFSET_DIR=telegram

# File fallback and local Docker path rewrite.
CLOUD_FILE_FALLBACK_MAX_BYTES=20971520
LOCAL_FILE_PATH_REWRITE_FROM=/var/lib/telegram-bot-api
LOCAL_FILE_PATH_REWRITE_TO=/home/danka/.openclaw/var/telegram-bot-api

# Proxy limits and timeouts.
BUFFER_LIMIT_BYTES=8388608
LOCAL_HEALTH_TTL_MS=5000
LOCAL_UNHEALTHY_COOLDOWN_MS=5000
LOCAL_HEALTH_TIMEOUT_MS=2000
UPSTREAM_TIMEOUT_MS=130000
CLOUD_PENDING_PROBE_TTL_MS=5000
CLOUD_FRESH_UPDATE_MAX_AGE_MS=21600000
